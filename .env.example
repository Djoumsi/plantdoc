# =====================================================
# PlantDoc — Configuration d'environnement
# Copier en .env et adapter les valeurs
# =====================================================

APP_NAME="PlantDoc"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/plantdoc
APP_TIMEZONE=Africa/Douala

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=plantdoc
DB_USER=root
DB_PASS=

# API Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1024

# Sécurité
SESSION_LIFETIME=120
CSRF_TOKEN_NAME=_csrf
BCRYPT_COST=10

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED=image/jpeg,image/png,image/webp

# Rate limiting (par heure)
RATE_LOGIN=5
RATE_DIAGNOSTIC=10
RATE_REGISTER=3
